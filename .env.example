# PORT for the backend server to run on
PORT=3000

# MongoDB Connection String (e.g., mongodb://127.0.0.1:27017/spotify-clone or MongoDB Atlas URI)
MONGODB_URI=mongodb://127.0.0.1:27017/spotify-clone

# JWT Secrets for authentication
# Generate strong secrets (e.g. using `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
ACCESS_TOKEN_SECRET=your_access_token_secret_here
ACCESS_TOKEN_EXPIRY=15m

REFRESH_TOKEN_SECRET=your_refresh_token_secret_here
REFRESH_TOKEN_EXPIRY=7d

# Cloudinary Configuration for Image/Audio Uploads
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# Frontend URL for CORS
CORS_ORIGIN=http://localhost:5174
